# Better Auth — session signing secret + base URL of the app
# Generate the secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace_with_random_64_hex_chars
BETTER_AUTH_URL=http://localhost:3000

# Extra origins allowed to log in, comma-separated (localhost:3000/3002/4242
# are always trusted). Add the address you actually browse from, e.g. a LAN IP:
# TRUSTED_ORIGINS=http://192.168.1.50:4242

# AES-256-GCM key for encrypting per-user Akahu tokens at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_random_64_hex_chars

# Akahu tokens are per-user and entered on the Settings page (stored encrypted
# in the user_settings table). These legacy env vars are only read once, by the
# first-signup data claim when upgrading a pre-auth single-user install:
# AKAHU_USER_TOKEN=user_token_xxx
# AKAHU_APP_TOKEN=app_token_xxx

# PostgreSQL connection string.
# Local dev (host → mapped port):  postgresql://lazybudget:lazybudget@localhost:5433/lazybudget
# Docker Compose (container → container): postgresql://lazybudget:lazybudget@postgres:5432/lazybudget
# Set the appropriate value in .env.local; the docker-compose.yml reads DATABASE_URL from the host
# environment at `docker compose up` time, so export it (or put it in a root-level .env file) when deploying.
DATABASE_URL=postgresql://lazybudget:lazybudget@localhost:5433/lazybudget
